# ============================================================
# Campus Knowledge Agent — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Server
NODE_ENV=development
PORT=5000
HOST=localhost

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# API
API_VERSION=v1

# AI Engine
AI_ENGINE_URL=http://localhost:8000
AI_ENGINE_TIMEOUT=30000

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Local development — use Firestore emulator (firebase emulators:start --only firestore)
FIREBASE_USE_EMULATOR=false
# Uncomment only when FIREBASE_USE_EMULATOR=true
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
LOG_DIR=logs
