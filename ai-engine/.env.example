# ============================================================
# Campus Knowledge Agent — AI Engine Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=debug

# Backend API (for data retrieval if needed)
BACKEND_API_URL=http://localhost:5000
BACKEND_API_TIMEOUT=30

# Model paths (Phase 6+)
DISTILBERT_MODEL_PATH=models/distilbert
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2
FAISS_INDEX_PATH=vectorstore/index/campus.index

# Google Vertex AI / Gemini (Phase 8)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-1.5-flash

# Inference settings
MAX_SEQUENCE_LENGTH=512
INTENT_CONFIDENCE_THRESHOLD=0.75
TOP_K_RESULTS=5
